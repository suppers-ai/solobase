#!/usr/bin/env bash
set -e

# ── Rust: fmt + clippy on staged .rs files ──────────────────────────
RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')
if [ -n "$RS_FILES" ]; then
  echo "Running cargo fmt --check..."
  cargo fmt --all -- --check || {
    echo "❌ cargo fmt failed. Run 'cargo fmt --all' and re-stage."
    exit 1
  }

  echo "Running cargo clippy..."
  cargo clippy --all-targets --all-features -- -D warnings 2>&1 || {
    echo "❌ clippy found warnings. Fix them and re-stage."
    exit 1
  }
fi

# ── JS/TS: prettier on staged files ─────────────────────────────────
JS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.js' '*.ts' '*.tsx' '*.jsx' '*.css')
if [ -n "$JS_FILES" ]; then
  # Find prettier: local cloud-dashboard install, or npx fallback
  PRETTIER="$(git rev-parse --show-toplevel)/packages/cloud-dashboard/node_modules/.bin/prettier"
  if [ ! -x "$PRETTIER" ]; then
    PRETTIER="$(command -v prettier 2>/dev/null || echo "")"
  fi
  if [ -n "$PRETTIER" ]; then
    echo "Running prettier --check..."
    echo "$JS_FILES" | xargs "$PRETTIER" --check || {
      echo "❌ prettier failed. Run 'npx prettier --write' on the listed files and re-stage."
      exit 1
    }
  fi
fi

echo "✓ Pre-commit checks passed."
