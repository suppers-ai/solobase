#!/usr/bin/env bash
set -e

# ── Rust: fmt + clippy on staged .rs files ──────────────────────────
RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')
if [ -n "$RS_FILES" ]; then
  echo "Running cargo fmt..."
  cargo fmt --all
  git add $RS_FILES

  echo "Running cargo clippy --fix..."
  cargo clippy -p solobase-core -p solobase --fix --allow-dirty --allow-staged -- -D warnings 2>&1 || {
    echo "❌ clippy found warnings it couldn't auto-fix. Please fix manually and re-stage."
    exit 1
  }
  git add $RS_FILES
fi

# ── JS/TS: prettier on staged files ─────────────────────────────────
JS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.js' '*.ts' '*.tsx' '*.jsx' '*.css')
if [ -n "$JS_FILES" ]; then
  # Find prettier: local cloud-dashboard install, or npx fallback
  PRETTIER="$(git rev-parse --show-toplevel)/packages/cloud-dashboard/node_modules/.bin/prettier"
  if [ ! -x "$PRETTIER" ]; then
    PRETTIER="$(command -v prettier 2>/dev/null || echo "")"
  fi
  if [ -n "$PRETTIER" ]; then
    echo "Running prettier --write..."
    echo "$JS_FILES" | xargs "$PRETTIER" --write
    git add $JS_FILES
  fi
fi

echo "✓ Pre-commit checks passed."
