# ==============================================================================
# Solobase Configuration
# ==============================================================================
# Copy to .env and customize. Auto-detected on startup.
# Override path with: SOLOBASE_ENV_FILE=/path/to/.env
#
# - SOLOBASE_* vars: infrastructure (process-only, not in dashboard)
# - Other vars: app config (seeded into variables table, dashboard-editable)
# - Dashboard edits take priority over .env values (INSERT OR IGNORE)

# ------------------------------------------------------------------------------
# Infrastructure (SOLOBASE_* prefix — process-only, not stored in database)
# ------------------------------------------------------------------------------
# SOLOBASE_LISTEN=0.0.0.0:8090
# SOLOBASE_DB_TYPE=sqlite
# SOLOBASE_DB_PATH=data/solobase.db
# SOLOBASE_STORAGE_TYPE=local
# SOLOBASE_STORAGE_ROOT=data/storage

# PostgreSQL (instead of SQLite):
# SOLOBASE_DB_TYPE=postgres
# SOLOBASE_DB_URL=postgres://user:pass@localhost:5432/solobase

# S3-compatible storage (instead of local):
# SOLOBASE_STORAGE_TYPE=s3

# ------------------------------------------------------------------------------
# App settings (seeded into variables table, editable via dashboard)
# ------------------------------------------------------------------------------
APP_NAME=Solobase
PRIMARY_COLOR=#6366f1
ALLOW_SIGNUP=true
# POST_LOGIN_REDIRECT=/blocks/admin/frontend/
# FRONTEND_URL=http://localhost:8090
# ADMIN_EMAIL=admin@example.com

# JWT secret for signing auth tokens (auto-generated if not set)
# JWT_SECRET=your-secret-key

# ------------------------------------------------------------------------------
# Block management (blocks are enabled/disabled via the admin UI)
# To disable blocks on first run, use comma-separated full block names:
# ------------------------------------------------------------------------------
# BLOCK_DISABLED=suppers-ai/legalpages,suppers-ai/userportal

# ------------------------------------------------------------------------------
# Stripe (optional — required for products block payments)
# ------------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# Email (optional — required for email verification, password reset)
# ------------------------------------------------------------------------------
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM=noreply@example.com

# ------------------------------------------------------------------------------
# Products webhook (optional — fires on billing events: checkout, subscription changes)
# ------------------------------------------------------------------------------
# PRODUCTS_WEBHOOK_URL=https://cloud.solobase.dev/_webhooks/products
# PRODUCTS_WEBHOOK_SECRET=your-webhook-secret

# ------------------------------------------------------------------------------
# Platform (cloud-only — deployments block provisioning)
# ------------------------------------------------------------------------------
# CONTROL_PLANE_URL=https://cloud.solobase.dev
# CONTROL_PLANE_SECRET=your-control-plane-secret
