# ==============================================================================
# Solobase Environment Configuration
# ==============================================================================
# Copy this file to .env and update values for your environment.
# For production, see .env.production.example for security recommendations.

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# SQLite (default - no config needed, uses .data/solobase.db)
# DATABASE_TYPE=sqlite
# DATABASE_PATH=.data/solobase.db

# PostgreSQL
DATABASE_TYPE=postgres
DATABASE_URL=postgres://solobase:solobase123@localhost:5432/solobase?sslmode=disable

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
PORT=8080
APP_ID=solobase
ENVIRONMENT=development
BASE_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# CRITICAL: Generate strong secrets for production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Argon2 password hashing memory (MB). Lower values = faster but less secure.
# Default: 64. For low-memory environments (WASM), use 16-32.
# ARGON2_MEMORY_MB=64

# ------------------------------------------------------------------------------
# Admin Account
# ------------------------------------------------------------------------------
# Default admin credentials (created on first run)
DEFAULT_ADMIN_EMAIL=admin@solobase.local
DEFAULT_ADMIN_PASSWORD=admin123

# ------------------------------------------------------------------------------
# Features
# ------------------------------------------------------------------------------
ENABLE_SIGNUP=true
ENABLE_API=true
LOG_LEVEL=DEBUG

# Disable UI or extensions if running API-only
# DISABLE_UI=true
# DISABLE_EXTENSIONS=true

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ------------------------------------------------------------------------------
# Storage (S3/MinIO)
# ------------------------------------------------------------------------------
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=solobase
S3_REGION=us-east-1
S3_USE_SSL=false

# ------------------------------------------------------------------------------
# Mail (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@solobase.local
SMTP_USE_TLS=false

# ------------------------------------------------------------------------------
# OAuth Providers (optional)
# ------------------------------------------------------------------------------
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Payments (optional)
# ------------------------------------------------------------------------------
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Advanced
# ------------------------------------------------------------------------------
# Trust X-Forwarded-For header (set true behind reverse proxy)
# TRUST_PROXY=false

# Read-only mode (disables writes, admin creation, migrations)
# READONLY_MODE=false

# Internal webhook secret (for OAuth sync callbacks)
# INTERNAL_SECRET=
