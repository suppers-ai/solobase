# ==============================================================================
# Solobase Production Configuration
# ==============================================================================
# IMPORTANT: Copy to .env and replace ALL placeholder values
# Generate secrets with: openssl rand -base64 32

# ------------------------------------------------------------------------------
# Database (PostgreSQL recommended for production)
# ------------------------------------------------------------------------------
DATABASE_TYPE=postgres
DATABASE_URL=postgres://solobase_user:CHANGE_TO_STRONG_PASSWORD@your-db-host:5432/solobase?sslmode=require

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
PORT=8080
APP_ID=solobase
ENVIRONMENT=production
BASE_URL=https://yourdomain.com

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# CRITICAL: Generate with: openssl rand -base64 32
JWT_SECRET=REQUIRED_CHANGE_THIS_USE_OPENSSL_RAND_BASE64_32

# Argon2 password hashing (default 64MB is recommended for production)
# ARGON2_MEMORY_MB=64

# ------------------------------------------------------------------------------
# Admin Account
# ------------------------------------------------------------------------------
# Use a strong password (12+ chars, mixed case, numbers, symbols)
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=CHANGE_TO_VERY_STRONG_PASSWORD_MIN_12_CHARS

# ------------------------------------------------------------------------------
# Features
# ------------------------------------------------------------------------------
ENABLE_SIGNUP=false
ENABLE_API=true
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ------------------------------------------------------------------------------
# Storage (S3)
# ------------------------------------------------------------------------------
STORAGE_TYPE=s3
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=CHANGE_TO_YOUR_ACCESS_KEY
S3_SECRET_KEY=CHANGE_TO_YOUR_SECRET_KEY
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_USE_SSL=true

# ------------------------------------------------------------------------------
# Mail (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=CHANGE_TO_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# ------------------------------------------------------------------------------
# OAuth Providers (optional)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Payments (optional)
# ------------------------------------------------------------------------------
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Advanced
# ------------------------------------------------------------------------------
# Trust X-Forwarded-For header (set true behind reverse proxy like nginx)
TRUST_PROXY=true

# ==============================================================================
# Production Checklist:
# ==============================================================================
# [ ] Generated strong JWT_SECRET (openssl rand -base64 32)
# [ ] Set strong DEFAULT_ADMIN_PASSWORD (12+ chars)
# [ ] Configured DATABASE_URL with SSL (sslmode=require)
# [ ] Set S3_USE_SSL=true
# [ ] Set SMTP_USE_TLS=true
# [ ] Configured CORS_ALLOWED_ORIGINS for your domain
# [ ] Set ENABLE_SIGNUP=false if not needed
# [ ] Configured rate limits appropriately
# [ ] Set up database backups
# [ ] Enabled monitoring/alerting
# [ ] Never commit .env to version control
