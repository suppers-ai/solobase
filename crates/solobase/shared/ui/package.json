{
  "name": "@solobase/ui",
  "version": "1.0.0",
  "description": "Shared Preact + HTM UI components for Solobase",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts",
    "./stores/auth": "./src/stores/auth.ts",
    "./stores/toast": "./src/stores/toast.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./css/*": "./src/css/*"
  },
  "peerDependencies": {
    "preact": "^10.0.0",
    "htm": "^3.0.0",
    "@preact/signals": "^1.0.0"
  },
  "dependencies": {
    "@solobase/types": "*",
    "lucide-preact": "^0.460.0"
  },
  "keywords": ["solobase", "ui", "preact", "htm"],
  "author": "Solobase Team",
  "license": "MIT"
}
