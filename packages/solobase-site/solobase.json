{
    "$schema": "https://solobase.dev/schemas/solobase.json",
    "version": 0,
    "app": "solobase-site",
    "listen": "0.0.0.0:${PORT:-8090}",
    "database": { "type": "sqlite", "path": "data/solobase-site.db" },
    "storage": { "type": "local", "root": "${STORAGE_ROOT:-./dist}" },
    "jwt_secret": "${JWT_SECRET}",
    "web_root": "site",
    "features": {}
}
